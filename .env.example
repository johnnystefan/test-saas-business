# =============================================================================
# .env.example — Environment variables for docker compose
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# This file (.env.example) IS committed — it documents required variables.
# =============================================================================

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------

# Port exposed to the host. The app always listens on :3000 inside the container.
API_GATEWAY_PORT=3000

# CORS allowed origins. Use * for development, restrict in production.
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Auth (shared across api-gateway + auth-service)
# ---------------------------------------------------------------------------

# JWT signing secret — generate with: openssl rand -base64 64
# REQUIRED — no default
JWT_SECRET=change-me-in-production

# Access token expiry. Standard: 15m (short-lived, rotated via refresh)
JWT_EXPIRY=15m

# Refresh token expiry. Standard: 7d
REFRESH_TOKEN_EXPIRY=7d

# ---------------------------------------------------------------------------
# PostgreSQL — Auth Service
# ---------------------------------------------------------------------------

POSTGRES_AUTH_USER=saas
# REQUIRED — no default. Generate with: openssl rand -base64 32
POSTGRES_AUTH_PASSWORD=change-me-in-production

# ---------------------------------------------------------------------------
# PostgreSQL — Club Service
# ---------------------------------------------------------------------------

POSTGRES_CLUB_USER=saas
# REQUIRED — no default. Generate with: openssl rand -base64 32
POSTGRES_CLUB_PASSWORD=change-me-in-production

# ---------------------------------------------------------------------------
# pgAdmin (optional — only started with: docker compose --profile tools up)
# ---------------------------------------------------------------------------

PGADMIN_EMAIL=admin@saas.local
PGADMIN_PASSWORD=admin
